# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/resume_screening?schema=public"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Provider (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Logging
LOG_LEVEL=debug
